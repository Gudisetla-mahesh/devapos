pipeline {
    agent any
    stages {
        stage('Checkout') {
           steps {
              echo 'Checking out code from Github..'
           }
        }
        stage('Build') {
           steps {
              echo 'Building the app...'
           }
        }
        stage('Test') {
           steps {
              echo 'Running tests...'
           }
        }
     }
}


